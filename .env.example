# ============================================================
# Al-Hidaayah Platinum Travels — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── SANITY CMS ────────────────────────────────────────────
# 1. Create a Sanity account at sanity.io
# 2. Create a new project
# 3. Copy your project ID and dataset name below

NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API token (for server-side operations — create in Sanity dashboard)
SANITY_API_TOKEN=your_sanity_api_token_here

# ─── EMAIL — RESEND ────────────────────────────────────────
# 1. Create an account at resend.com
# 2. Add and verify your domain
# 3. Generate an API key

RESEND_API_KEY=your_resend_api_key_here

# ─── CLIENT CONTACT ────────────────────────────────────────
# Email address where inquiry notifications are sent

CLIENT_EMAIL=info@alhidaayahplatinumtravels.co.uk

# ─── SITE URL ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.alhidaayahplatinumtravels.co.uk

# ─── GOOGLE ANALYTICS (optional) ──────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
